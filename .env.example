# ============== Server ==============
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# ============== Database ==============
DATABASE_URL=postgresql://koda:koda_secret@localhost:5433/kodaback?schema=public

# ============== Auth ==============
JWT_SECRET=change-me-in-production-this-must-be-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=change-me-in-production-different-from-jwt-secret-also-long-random
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============== Logging ==============
LOG_LEVEL=info
LOG_PRETTY=true

# ============== Rate Limiting ==============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200