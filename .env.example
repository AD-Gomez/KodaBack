# ============== Server ==============
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173,https://kodahouses.com,https://www.kodahouses.com

# ============== Database ==============
DATABASE_URL=postgresql://koda:koda_secret@localhost:5433/kodaback?schema=public

# ============== Auth ==============
JWT_SECRET=change-me-in-production-this-must-be-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=change-me-in-production-different-from-jwt-secret-also-long-random
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============== Logging ==============
LOG_LEVEL=info
LOG_PRETTY=true

# ============== Rate Limiting ==============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ============== Email (Brevo) ==============
# API key del SMTP/API de Brevo (https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=
EMAIL_FROM=legal@kodahouses.com
EMAIL_FROM_NAME="KodaHouse · Legal"
# URL pública del frontend usada para construir links de firma
FRONTEND_PUBLIC_URL=https://kodahouses.com

# ============== AWS S3 (cédulas + PDFs firmados) ==============
AWS_REGION=us-east-1
# Bucket donde se subirán las fotos de cédula (frente/reverso) y el PDF firmado.
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: URL pública base (CloudFront / CDN propio). Si está vacía, la API genera URLs temporales firmadas de S3.
# AWS_S3_PUBLIC_URL=
